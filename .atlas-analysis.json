  "keyFeatures": [
    "Context isolation with AsyncLocalStorage",
    "Accumulate fields throughout request lifecycle",
    "Single structured log per request",
    "Dot notation for nested objects",
    "Built-in timing and aggregation operations",
    "Error field extraction",
    "Automatic log level routing",
    "Pretty-print in development, JSON in production"
  ],
  "publicApiSurface": [
    "widelogger(options)",
    "widelog.context(fn)",
    "widelog.set(key, value)",
    "widelog.count(key, amount?)",
    "widelog.append(key, value)",
    "widelog.max(key, value)",
    "widelog.min(key, value)",
    "widelog.time.start(key)",
    "widelog.time.stop(key)",
    "widelog.errorFields(error, opts?)",
    "widelog.flush()",
    "destroy()"
  ]
